<SpinePage
    xmlns="http://schemas.microsoft.com/dotnet/maui/global"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MauiSpineSampleApp.Pages.SmallSheetPage"
    x:TypeArguments="SmallSheetPageViewModel"
    x:DataType="SmallSheetPageViewModel">

    <VerticalStackLayout Padding="24" Spacing="12">
        <Label Text="Small sheet (compact detent)" />
        <Button Text="Close" Command="{Binding CloseCommand}" />
    </VerticalStackLayout>

</SpinePage>
