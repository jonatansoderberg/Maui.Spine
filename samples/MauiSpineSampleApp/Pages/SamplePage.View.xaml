<SpinePage
    xmlns="http://schemas.microsoft.com/dotnet/maui/global"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MauiSpineSampleApp.Pages.SamplePage"
    x:TypeArguments="SamplePageViewModel"
    x:DataType="SamplePageViewModel">

    <VerticalStackLayout Padding="24" Spacing="5">
        <Label Text="Hello"/>
        <Label Text="{Binding UserName}"/>
        <Button Text="Next" Command="{Binding NextCommand}" />
    </VerticalStackLayout>
    
</SpinePage>
