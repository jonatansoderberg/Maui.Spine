<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/maui/global"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiBottomSheetPoc.ContextItem">
    <ContentView.Content>
        <Border 
            BackgroundColor="Transparent"
                Stroke="Gray"
                StrokeThickness="0"
                Padding="2"
                Margin="0">

            <Grid ColumnDefinitions="50,*,30" Padding="0" Margin="0">


                <Image
                    Grid.Column="0"
                    WidthRequest="50"
                    HeightRequest="50"
                    SvgImageSource.Svg="fish.svg" />




                <Label Grid.Column="1" Text="{Binding Title}" FontSize="18" VerticalOptions="Center"/>

            </Grid>
        </Border>
    </ContentView.Content>

</ContentView>
