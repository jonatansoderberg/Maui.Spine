<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/maui/global"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiBottomSheetPoc.ContextItem"
             x:Name="Root">

    <Border
        BackgroundColor="Transparent"
        Stroke="Gray"
        StrokeThickness="0"
        Padding="8,6"
        Margin="0">

        <Grid ColumnDefinitions="40, *, Auto" RowDefinitions="Auto, Auto"
              ColumnSpacing="12" RowSpacing="0"
              Padding="0" Margin="0">

            <!-- Icon (spans both rows, vertically centered) -->
            <Image
                Grid.Column="0"
                Grid.RowSpan="2"
                WidthRequest="36"
                HeightRequest="36"
                VerticalOptions="Center"
                SvgImageSource.Svg="{Binding Icon, Source={x:Reference Root}}" />

            <!-- Title -->
            <Label
                Grid.Column="1"
                Grid.Row="0"
                Text="{Binding Title, Source={x:Reference Root}}"
                FontSize="16"
                FontAttributes="Bold"
                TextTransform="Uppercase"
                LineBreakMode="TailTruncation"
                MaxLines="1"
                VerticalOptions="End" />

            <!-- Description (optional, AnimatedLabel with marquee) -->
            <AnimatedLabel
                x:Name="DescriptionLabel"
                Grid.Column="1"
                Grid.Row="1"
                Text="{Binding Description, Source={x:Reference Root}}"
                FontSize="12"
                TextColor="Gray"
                HeightRequest="18"
                IsVisible="False"
                VerticalOptions="Start" />

            <!-- Actions slot (optional, right-aligned) -->
            <ContentView
                x:Name="ActionsContainer"
                Grid.Column="2"
                Grid.RowSpan="2"
                VerticalOptions="Center"
                IsVisible="False" />

        </Grid>
    </Border>

</ContentView>
